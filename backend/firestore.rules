rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Funciones de ayuda
    function isAuthenticated() { return request.auth != null; }
    function isAuthor(existingData) { return isAuthenticated() && request.auth.uid == existingData.author.uid; }
    function isIncomingDataValid() {
      let data = request.resource.data;
      return data.keys().hasAll(['title', 'content', 'author', 'media', 'metadata'])
             && data.title is string
             && data.content is string
             && data.media.thumbnailURL is string;
    }

    match /articles/{articleId} {
      
      // 1. Accessibility: El PÚBLICO puede leer artículos publicados. El autor puede leer sus propios borradores.
      allow read: if resource.data.metadata.status == 'published' 
                  || (isAuthenticated() && resource.data.author.uid == request.auth.uid);

      // 2. Integrity: El autor debe estar logueado, ser él mismo, y enviar los campos obligatorios.
      allow create: if isAuthenticated() 
                    && request.resource.data.author.uid == request.auth.uid
                    && isIncomingDataValid();

      // 3. Ownership: Solo el autor puede actualizar o borrar. No puede transferir la autoría.
      allow update: if isAuthor(resource.data)
                    && request.resource.data.author.uid == resource.data.author.uid;
      
      allow delete: if isAuthor(resource.data);
    }
  }
}